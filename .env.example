# HTTP port exposed by the API.
PORT=3000

# Fixed bearer token expected by protected endpoints.
AUTH_TOKEN=dev-token

# PostgreSQL user used by docker compose.
POSTGRES_USER=upsurge

# PostgreSQL password used by docker compose.
POSTGRES_PASSWORD=upsurge

# Host port exposed by docker compose for local PostgreSQL access.
POSTGRES_PORT=5433

# PostgreSQL connection string used by local commands outside docker compose.
DATABASE_URL=postgres://upsurge:upsurge@localhost:5433/upsurge

# Stripe publishable key placeholder for test mode references.
STRIPE_PUBLISHABLE_KEY=pk_test_stripe

# Stripe secret key used to create test PaymentIntents.
STRIPE_SECRET_KEY=sk_test_stripe

# Stripe webhook signing secret used to validate incoming Stripe events.
STRIPE_WEBHOOK_SECRET=whsec_stripe

# Currency used when creating Stripe PaymentIntents.
STRIPE_CURRENCY=brl

# Stripe test payment method used by backend-only card payments.
STRIPE_TEST_PAYMENT_METHOD_ID=pm_card_visa
