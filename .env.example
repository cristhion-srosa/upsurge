PORT=3000
AUTH_TOKEN=dev-token
POSTGRES_USER=upsurge
POSTGRES_PASSWORD=upsurge
POSTGRES_PORT=5433
DATABASE_URL=postgres://upsurge:upsurge@localhost:5433/upsurge

# Redis connection used by BullMQ.
REDIS_URL=redis://localhost:6379

# Host port exposed by docker compose for local Redis access.
REDIS_PORT=6379

# Maximum attempts for each payment webhook job.
PAYMENT_WEBHOOK_JOB_ATTEMPTS=3

# Initial exponential backoff delay between retries, in milliseconds.
PAYMENT_WEBHOOK_JOB_BACKOFF_DELAY_MS=1000

# Maximum age for completed jobs kept in Redis, in seconds.
PAYMENT_WEBHOOK_JOB_REMOVE_ON_COMPLETE_AGE_SECONDS=604800

# Maximum number of completed jobs kept in Redis.
PAYMENT_WEBHOOK_JOB_REMOVE_ON_COMPLETE_COUNT=10000

# Maximum age for failed jobs kept in Redis, in seconds.
PAYMENT_WEBHOOK_JOB_REMOVE_ON_FAIL_AGE_SECONDS=2592000

# Maximum number of failed jobs kept in Redis.
PAYMENT_WEBHOOK_JOB_REMOVE_ON_FAIL_COUNT=10000

# Number of payment webhook jobs processed in parallel by the worker.
PAYMENT_WEBHOOK_WORKER_CONCURRENCY=5

STRIPE_PUBLISHABLE_KEY=pk_test_stripe
STRIPE_SECRET_KEY=sk_test_stripe
STRIPE_WEBHOOK_SECRET=whsec_stripe
STRIPE_CURRENCY=brl
STRIPE_TEST_PAYMENT_METHOD_ID=pm_card_visa
